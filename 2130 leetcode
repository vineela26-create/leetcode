class Solution {
    public ListNode reverse(ListNode head) {
    ListNode prev = null;
    ListNode curr = head;

    while (curr != null) {
        ListNode next = curr.next;
        curr.next = prev;
        prev = curr;
        curr = next;
    }

    return prev;
}

public int pairSum(ListNode head) {
    ListNode slow = head;
    ListNode fast = head;

    while (fast != null && fast.next != null) {
        slow = slow.next;
        fast = fast.next.next;
    }

    ListNode k = reverse(slow);

    int maxSum = 0;
    ListNode first = head;

    while (k != null) {
        maxSum = Math.max(maxSum, first.val + k.val);
        first = first.next;
        k = k.next;
    }

    return maxSum;

    }
}
