import java.util.*;
class Solution {
    public void merge(int[] nums1, int m, int[] nums2, int n) {
    List<Integer> res = new ArrayList<>();
    for(int i = 0; i < m; i++) {
        res.add(nums1[i]);
    }
    for(int j = 0; j < n; j++) {
        res.add(nums2[j]);
    }
    Collections.sort(res);
    for(int i = 0; i < m + n; i++) {
        nums1[i] = res.get(i);
    }
  }
}
