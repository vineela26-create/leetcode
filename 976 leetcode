class Solution {
    public int largestPerimeter(int[] nums) {
        Arrays.sort(nums);
        int sum=0;
        for(int i = 2; i < nums.length; i++) {
          int a = nums[i];
         int b = nums[i - 1];
         int c = nums[i - 2];
        if(c + b > a) {
        sum = Math.max(sum,a + b + c);
       }
     }
      return sum;
    }
}
