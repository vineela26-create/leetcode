class Solution {
    public long maxTotalValue(int[] nums, int k) {
    long sum = 0;
    long min = Long.MAX_VALUE;
    long max = Long.MIN_VALUE;
    for (int i = 0; i < nums.length; i++) {
        if (min > nums[i]) {
            min = nums[i];
        }
    }
    for (int i = 0; i < nums.length; i++) {
        if (max < nums[i]) {
            max = nums[i];
        }
    }
    return (long)k*(max-min);
  }
}
  
